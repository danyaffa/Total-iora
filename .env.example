# Core app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEV_BYPASS=0
FAITH_OVERRIDE=

# Login/register backend (required for /api/login and /api/register)
# Use a Firebase service account with Firestore access.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep PEM newlines escaped as \n when stored in one line.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional client Firebase config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional owner promotion on login (comma-separated emails)
OWNER_EMAILS=
