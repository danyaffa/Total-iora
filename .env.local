# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Firebase Web App Config ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=0000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:0000000000:web:abcdef

# --- Stripe (Checkout Links) ---
NEXT_PUBLIC_STRIPE_MONTHLY_LINK=https://buy.stripe.com/xxxxxx
NEXT_PUBLIC_STRIPE_LIFETIME_LINK=https://buy.stripe.com/yyyyyy

# --- App Meta ---
NEXT_PUBLIC_APP_NAME=AuraCode
NEXT_PUBLIC_APP_DOMAIN=ahuracode.com
